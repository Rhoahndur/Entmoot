# Database Configuration
POSTGRES_DB=entmoot
POSTGRES_USER=entmoot
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# Application Configuration
ENVIRONMENT=production
SECRET_KEY=change-this-in-production-to-a-long-random-string

# Upload Configuration
MAX_UPLOAD_SIZE=52428800

# CORS Configuration (comma-separated origins)
# In production, list explicit origins — wildcard '*' is rejected.
ENTMOOT_CORS_ORIGINS=http://localhost:3000,http://localhost:80

# API Authentication
# Comma-separated list of valid API keys. Leave empty to disable key checking.
ENTMOOT_API_KEYS=
# Set to false to disable authentication entirely (development only).
ENTMOOT_AUTH_ENABLED=false

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=80

# Docker Registry (for deployment)
DOCKER_USERNAME=your-dockerhub-username
